<view class="container">
  <view class="dashboard-header">
    <view class="status-group">
      <view class="dot {{connected ? 'active' : ''}}"></view>
      <text class="status-text">{{connected ? '已连接' : '未连接'}}</text>
    </view>
    <view class="mode-selector" bindtap="toggleMode">
      <text class="mode-label">驾驶模式</text>
      <text class="mode-val">{{mode === 0 ? '蓝牙手控' : '遥控模式'}}</text>
    </view>
  </view>

  <!-- Speed Arc Section -->
  <view class="speedometer-section">
    <view class="arc-container">
      <view class="arc-bg"></view>
      <view class="arc-active" style="transform: rotate({{speedDeg}}deg)"></view>
      <view class="speed-info">
        <text class="speed-num">{{speed}}</text>
        <text class="speed-unit">RPM</text>
      </view>
    </view>
  </view>

  <!-- Main Stats Grid -->
  <view class="metrics-grid">
    <view class="metric-card glass">
      <view class="metric-header">
        <text class="label">电池电压</text>
        <text class="val" style="color: {{batColor}}">{{telemetry.batVoltage || 0}}V</text>
      </view>
      <view class="progress-track">
        <view class="progress-bar" style="width: {{batPercent}}%; background: {{batColor}}"></view>
      </view>
      <text class="percent-tag">{{batPercent}}%</text>
    </view>

    <view class="metric-card glass">
      <view class="metric-header">
        <text class="label">主板温度</text>
        <text class="val" style="color: {{tempColor}}">{{telemetry.boardTemp || 0}}°C</text>
      </view>
      <view class="progress-track">
        <view class="progress-bar" style="width: {{telemetry.boardTemp * 1.25}}%; background: {{tempColor}}"></view>
      </view>
    </view>

    <view class="metric-card glass wide">
      <view class="metric-header">
        <text class="label">电机负载</text>
        <view class="load-labels">
          <text>左: {{telemetry.cmd1}}</text>
          <text>右: {{telemetry.cmd2}}</text>
        </view>
      </view>
      <view class="dual-bar">
        <progress percent="{{absCmd1 / 10}}" activeColor="#00d2ff" backgroundColor="rgba(255,255,255,0.05)" stroke-width="2" />
        <progress percent="{{absCmd2 / 10}}" activeColor="#00d2ff" backgroundColor="rgba(255,255,255,0.05)" stroke-width="2" />
      </view>
    </view>
  </view>

  <view class="footer-actions">
    <button wx:if="{{mode === 0}}" class="action-btn primary" bindtap="enterJoystick">摇杆控制</button>
    <button class="action-btn" bindtap="sendPing">测试通讯</button>
    <button class="action-btn danger" bindtap="disconnect">断开连接</button>
  </view>
</view>
