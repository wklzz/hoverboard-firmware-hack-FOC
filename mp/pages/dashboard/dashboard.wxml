<view class="container">
  <view class="top-bar">
    <view class="conn-status">
      <view class="dot {{connected ? 'active' : ''}}"></view>
      <text>{{connected ? '已连接' : '已断开'}}</text>
    </view>
    <view class="mode-tag {{mode === 1 ? 'remote' : ''}}" bindtap="toggleMode">
      模式: {{mode === 0 ? '蓝牙控制' : '遥控模式'}}
    </view>
  </view>

  <!-- 速度表盘 -->
  <view class="gauge-section">
    <view class="speed-gauge">
      <view class="gauge-bg"></view>
      <view class="gauge-fill" style="transform: rotate({{speedDeg}}deg)"></view>
      <view class="speed-value">
        <text class="num">{{speed}}</text>
        <text class="unit">RPM</text>
      </view>
    </view>
  </view>

  <!-- 详细数据卡片 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="label">电池电压</text>
      <view class="value-row">
        <text class="val">{{telemetry.batVoltage || 0}}</text>
        <text class="unit">V</text>
      </view>
      <view class="progress-bg">
        <view class="progress-fill" style="width: {{batPercent}}%; background: {{batColor}}"></view>
      </view>
    </view>

    <view class="stat-card">
      <text class="label">主板温度</text>
      <view class="value-row">
        <text class="val">{{telemetry.boardTemp || 0}}</text>
        <text class="unit">°C</text>
      </view>
       <view class="progress-bg">
        <view class="progress-fill" style="width: {{telemetry.boardTemp * 1.2}}%; background: {{tempColor}}"></view>
      </view>
    </view>

    <view class="stat-card wide">
      <text class="label">电机功率负载</text>
      <view class="power-bars">
        <view class="bar-item">
          <text>左: {{telemetry.cmd1}}</text>
          <progress percent="{{absCmd1 / 10}}" activeColor="#00d2ff" backgroundColor="#222" stroke-width="4" />
        </view>
        <view class="bar-item">
          <text>右: {{telemetry.cmd2}}</text>
          <progress percent="{{absCmd2 / 10}}" activeColor="#00d2ff" backgroundColor="#222" stroke-width="4" />
        </view>
      </view>
    </view>
  </view>

  <view class="footer-actions">
    <button wx:if="{{mode === 0}}" class="action-btn primary" bindtap="enterJoystick">摇杆控制</button>
    <button class="action-btn" bindtap="sendPing">测试通讯</button>
    <button class="action-btn danger" bindtap="disconnect">断开连接</button>
  </view>
</view>
