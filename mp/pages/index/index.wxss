page {
  background-color: #121212;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 60rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  display: block;
  background: linear-gradient(90deg, #00d2ff 0%, #3a7bd5 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  margin-top: 10rpx;
  display: block;
}

.device-list {
  flex: 1;
  overflow: hidden;
}

.device-item {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.device-item:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
}

.device-name {
  font-size: 32rpx;
  font-weight: 500;
  display: block;
}

.device-id {
  font-size: 22rpx;
  color: #666;
  margin-top: 6rpx;
  display: block;
}

.rssi-box {
  background: rgba(0, 210, 255, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.rssi {
  font-size: 24rpx;
  color: #00d2ff;
  font-family: monospace;
}

.empty-tip {
  text-align: center;
  color: #444;
  margin-top: 100rpx;
  font-size: 28rpx;
}

.footer {
  padding: 40rpx 0;
}

.scan-btn {
  background: linear-gradient(90deg, #00d2ff 0%, #3a7bd5 100%);
  color: white;
  border-radius: 100rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx rgba(0, 210, 255, 0.3);
}

.scan-btn.scanning {
  background: #333;
  color: #888;
  box-shadow: none;
}
