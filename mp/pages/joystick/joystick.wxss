.container {
  height: 100vh;
  overflow: hidden;
  background: #050505;
  color: #fff;
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  box-sizing: border-box;
}

/* Header Minimal */
.header-minimal {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stat-pill {
  flex: 1;
  background: rgba(255, 255, 255, 0.03);
  padding: 20rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.stat-pill.main {
  background: rgba(0, 210, 255, 0.05);
  border-color: rgba(0, 210, 255, 0.1);
}

.stat-pill .lab {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.stat-pill .val {
  font-size: 32rpx;
  font-weight: bold;
  color: #e0e0e0;
}

.stat-pill.main .val {
  color: #00d2ff;
}

/* Control Config Tabs */
.control-config {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.mode-tabs {
  background: rgba(255, 255, 255, 0.03);
  padding: 8rpx;
  border-radius: 100rpx;
  display: flex;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.tab {
  padding: 12rpx 40rpx;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 100rpx;
  color: rgba(255, 255, 255, 0.3);
  transition: all 0.3s;
}

.tab.active {
  background: #00d2ff;
  color: #000;
}

/* Joystick Area */
.joystick-area {
  flex: 1;
  position: relative;
  background: rgba(255, 255, 255, 0.01);
  border-radius: 40rpx;
  border: 1px dashed rgba(255, 255, 255, 0.03);
  overflow: hidden;
}

.joystick-visual {
  width: 600rpx;
  height: 600rpx;
  position: absolute;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.joystick-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 210, 255, 0.05) 0%, transparent 70%);
  border: 2rpx solid rgba(0, 210, 255, 0.1);
}

.joystick-stick {
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle at 30% 30%, #4facfe 0%, #00f2fe 100%);
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  margin-left: -80rpx;
  margin-top: -80rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 210, 255, 0.4);
  border: 4rpx solid rgba(255, 255, 255, 0.2);
}

.axis-debug {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  font-family: monospace;
  font-size: 20rpx;
  color: rgba(0, 210, 255, 0.4);
}

/* Speed Panel */
.speed-panel {
  background: rgba(255, 255, 255, 0.03);
  padding: 30rpx;
  border-radius: 32rpx;
  margin: 40rpx 0;
}

.speed-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.speed-info .label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: bold;
}

.speed-info .val {
  font-size: 20rpx;
  color: #00d2ff;
  font-weight: bold;
}

/* Footer Buttons */
.footer-btns {
  display: flex;
  gap: 20rpx;
}

.btn-stop {
  flex: 2;
  background: #ff4d4d;
  color: #000;
  font-weight: 900;
  font-size: 24rpx;
  border-radius: 24rpx;
  padding: 24rpx 0;
}

.btn-back {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
  border-radius: 24rpx;
  padding: 24rpx 0;
  border: 1px solid rgba(255, 255, 255, 0.08);
}
