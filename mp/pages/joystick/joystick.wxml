<view class="container">
  <dashboard-header connected="{{connected}}" mode="{{mode}}" bind:toggle="toggleMode" bind:disconnect="disconnect" />
  <view class="header-minimal">
    <view class="stat-pill">
      <text class="lab">电压</text>
      <text class="val">{{telemetry.batVoltage || 0}}V</text>
    </view>
    <view class="stat-pill main">
      <text class="lab">速度</text>
      <text class="val">{{speed}}</text>
    </view>
    <view class="stat-pill">
      <text class="lab">温度</text>
      <text class="val">{{telemetry.boardTemp || 0}}°</text>
    </view>
  </view>

  <view class="control-config">
    <view class="mode-tabs">
      <view class="tab {{controlMode === 'fixed' ? 'active' : ''}}" bindtap="setControlMode" data-mode="fixed">固定中心</view>
      <view class="tab {{controlMode === 'floating' ? 'active' : ''}}" bindtap="setControlMode" data-mode="floating">动态浮动</view>
    </view>
  </view>

  <!-- Joystick Section -->
  <view class="joystick-area" 
        catchtouchstart="touchStart" 
        catchtouchmove="touchMove" 
        catchtouchend="touchEnd">
    
    <view wx:if="{{controlMode === 'fixed' || (controlMode === 'floating' && touching)}}"
          class="joystick-visual"
          style="left: {{visualX}}px; top: {{visualY}}px;">
      <view class="joystick-bg"></view>
      <view class="joystick-stick" 
            style="transform: translate({{stickX}}px, {{stickY}}px)"></view>
    </view>
    
    <view class="axis-debug" wx:if="{{touching}}">
      <text>S: {{steer}}</text>
      <text>T: {{throttle}}</text>
    </view>
  </view>

  <!-- Speed Limit Adjustment -->
  <view class="speed-panel">
    <view class="speed-info">
      <text class="label">输出档位限制</text>
      <text class="val">{{speedLimit}}%</text>
    </view>
    <view class="tier-selector">
      <view class="tier {{speedLimit === 25 ? 'active' : ''}}" bindtap="setTier" data-val="25">1档</view>
      <view class="tier {{speedLimit === 50 ? 'active' : ''}}" bindtap="setTier" data-val="50">2档</view>
      <view class="tier {{speedLimit === 75 ? 'active' : ''}}" bindtap="setTier" data-val="75">3档</view>
      <view class="tier {{speedLimit === 100 ? 'active' : ''}}" bindtap="setTier" data-val="100">4档</view>
    </view>
  </view>
</view>
