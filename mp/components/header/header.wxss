.dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.status-group {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background: #ff4d4d;
  border-radius: 50%;
  margin-right: 16rpx;
  box-shadow: 0 0 15rpx rgba(255, 77, 77, 0.6);
}

.dot.active {
  background: #00ffaa;
  box-shadow: 0 0 15rpx rgba(0, 255, 170, 0.6);
}

.status-text {
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.5);
  text-transform: uppercase;
}

.disconnect-btn {
  margin-left: 20rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 77, 77, 0.1);
  color: #ff4d4d;
  font-size: 18rpx;
  border-radius: 8rpx;
  border: 1px solid rgba(255, 77, 77, 0.2);
  font-weight: bold;
}

.mode-selector {
  text-align: right;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 12rpx;
}

.mode-label {
  display: block;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-bottom: 4rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.mode-val {
  font-size: 24rpx;
  font-weight: bold;
  color: #00d2ff;
  text-shadow: 0 0 20rpx rgba(0, 210, 255, 0.3);
}
